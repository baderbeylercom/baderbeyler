---
import type { EventEntry } from '../../lib/content';
import { formatDateLong, formatDateShort } from '../../lib/format';
import { getSiteData } from '../../lib/site-data';

interface Props {
  events: EventEntry[];
}

const { events } = Astro.props;
const { eventsContent } = await getSiteData();
const ap = eventsContent.appearance;
const eventsStyle = `--events-title-size:${ap.titleSize}rem;--events-card-title-size:${ap.cardTitleSize}rem;--section-padding-y:${ap.paddingY}rem;--events-list-gap:${ap.listMarginTop}rem;`;

const registrationEvents = events.filter(e => e.data.registrationUrl);
---

<section class="section events snap-section" id="events" style={eventsStyle}>
  <div class="reveal">
    <p class="section-tag">{eventsContent.eyebrow}</p>
    <h2 class="section-title" set:html={eventsContent.title}></h2>
  </div>

  {
    events.length > 0 && (
      <div class="events-list">
        {events.map((event, index) => (
          <article class="event-card featured-event reveal" style={`transition-delay:.${index + 1}s`}>
            <div class="event-copy">
              <div class="event-card-heading">
                <div class="event-header-title-wrap">
                  <h4 class="event-header-title">{event.data.title}</h4>
                  <div class="event-date-badge">{formatDateShort(event.data.startDate)}</div>
                </div>
                <button
                  type="button"
                  class="event-card-toggle"
                  aria-expanded="false"
                  aria-label={`${event.data.title} detaylarini goster`}
                >
                  <svg class="event-card-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </button>
              </div>
              <div class="event-card-body">
                <div class="event-card-body-inner">
                  <p class="event-address">{event.data.address ?? `${event.data.city}, ${event.data.venue}`}</p>
                  <p class="event-time">{event.data.timeLabel}</p>
                  <p>{event.data.description}</p>
                  <div class="event-actions">
                    {event.data.mapUrl && (
                      <a href={event.data.mapUrl} target="_blank" rel="noreferrer" class="event-action primary">
                        Haritada Aç
                      </a>
                    )}
                    {event.data.registrationUrl && (
                      <button
                        type="button"
                        class="event-action event-register-btn"
                        data-reg-modal={`reg-modal-${index}`}
                      >
                        Yerini Ayırt
                      </button>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <div class="event-map">
              {event.data.mapEmbedUrl ? (
                <iframe
                  title={`${event.data.title} konum haritası`}
                  src={event.data.mapEmbedUrl}
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
              ) : (
                <div class="event-map-fallback">
                  <span>{formatDateLong(event.data.startDate)}</span>
                  <strong>{event.data.venue}</strong>
                </div>
              )}
            </div>
            <div class="editor-resize-handle editor-resize-handle--event-card" data-editor-resize="event-card-height" aria-hidden="true"></div>
          </article>
        ))}
      </div>
    )
  }

  {
    events.length === 0 && (
      <div class="agenda-block reveal">
        <div class="agenda-header">
          <p class="section-tag">Etkinlik Takvimi</p>
          <h3 class="agenda-title" set:html={eventsContent.emptyTitle}></h3>
          <p>{eventsContent.emptyText}</p>
        </div>
      </div>
    )
  }
</section>

{events.map((event, index) => event.data.registrationUrl && (
  <div id={`reg-modal-${index}`} class="reg-modal" role="dialog" aria-modal="true" aria-label="Kayıt Formu">
    <div class="reg-modal-backdrop"></div>
    <div class="reg-modal-content">
      <button class="reg-modal-close" aria-label="Kapat">&#x2715;</button>
      <div class="reg-modal-body">
        <p class="reg-modal-eyebrow">Etkinlik Kaydı</p>
        <h3 class="reg-modal-title">{event.data.registrationLabel ?? event.data.title}</h3>
        <p class="reg-modal-desc">Formu doldurarak yerinizi ayırtabilirsiniz.</p>
        <a
          href={event.data.registrationUrl}
          target="_blank"
          rel="noreferrer"
          class="reg-modal-cta"
        >
          Form Doldur →
        </a>
      </div>
    </div>
  </div>
))}

<style>
  .event-card-heading {
    display: block;
  }

  .event-card-toggle {
    display: none;
    width: auto;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
  }

  .event-card-chevron {
    width: 1.1rem;
    height: 1.1rem;
  }

  /* ── Mobil Accordion ── */
  @media (max-width: 768px) {
    .event-card {
      padding: 0 !important;
      min-height: unset !important;
      height: auto !important;
    }

    .event-map { display: none !important; }

    .event-card-heading {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.7rem 1rem;
    }

    .event-card-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      min-width: 2rem;
      padding: 0.25rem;
      cursor: pointer;
      flex-shrink: 0;
    }

    .event-header-title-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .event-header-title {
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--clr-deep);
      margin: 0;
      line-height: 1.25;
    }

    .event-date-badge {
      font-size: 0.74rem;
      font-weight: 700;
      color: var(--clr-terracotta);
      background: rgba(53, 73, 92, 0.08);
      padding: 0.18rem 0.45rem;
      border-radius: 5px;
      white-space: nowrap;
      align-self: flex-start;
    }

    .event-card-chevron {
      width: 1.1rem;
      height: 1.1rem;
      flex-shrink: 0;
      color: var(--clr-terracotta);
      transition: transform 0.28s ease;
    }

    .event-card.open .event-card-chevron { transform: rotate(180deg); }

    .event-card-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.28s ease;
    }

    .event-card-body-inner {
      padding: 0 1rem;
      transition: padding 0.28s ease;
    }

    .event-card.open .event-card-body {
      max-height: 420px;
    }

    .event-card.open .event-card-body-inner {
      padding: 0.1rem 1rem 1rem;
    }
  }

  .event-register-btn {
    background: none;
    border: 1px solid currentColor;
    cursor: pointer;
    font: inherit;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    transition: background 0.2s, color 0.2s;
  }
  .event-register-btn:hover {
    background: currentColor;
    color: #fff;
  }

  .reg-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .reg-modal.open {
    pointer-events: auto;
    opacity: 1;
  }

  .reg-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.75);
    cursor: pointer;
  }

  .reg-modal-content {
    position: relative;
    z-index: 1;
    background: #fff;
    border-radius: 1.25rem;
    padding: 2.5rem 2.75rem;
    max-width: min(90vw, 480px);
    width: 100%;
    transform: translateY(24px) scale(0.97);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    text-align: center;
  }
  .reg-modal.open .reg-modal-content {
    transform: translateY(0) scale(1);
  }

  .reg-modal-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    color: #888;
    transition: color 0.2s;
  }
  .reg-modal-close:hover { color: #111; }

  .reg-modal-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 0.5rem;
  }

  .reg-modal-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .reg-modal-desc {
    font-size: 0.95rem;
    color: #555;
    margin-bottom: 1.75rem;
  }

  .reg-modal-cta {
    display: inline-block;
    background: #3b1f55;
    color: #fff;
    text-decoration: none;
    padding: 0.75rem 2rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.97rem;
    transition: opacity 0.2s;
  }
  .reg-modal-cta:hover { opacity: 0.85; }
</style>

<script>
  const syncEventAccordions = () => {
    document.querySelectorAll<HTMLElement>('.event-card').forEach((card) => {
      const toggle = card.querySelector<HTMLButtonElement>('.event-card-toggle');
      if (!toggle) return;
      toggle.setAttribute('aria-expanded', card.classList.contains('open') ? 'true' : 'false');
    });
  };

  const closeOpenEventCards = () => {
    document.querySelectorAll<HTMLElement>('.event-card.open').forEach((card) => {
      card.classList.remove('open');
    });
  };

  document.querySelectorAll<HTMLButtonElement>('.event-card-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      if (window.innerWidth > 768) return;
      const card = toggle.closest<HTMLElement>('.event-card');
      if (!card) return;
      const isOpen = card.classList.contains('open');
      closeOpenEventCards();
      if (!isOpen) card.classList.add('open');
      syncEventAccordions();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.event-register-btn').forEach((btn) => {
    btn.addEventListener('click', (event) => {
      event.stopPropagation();
      const modalId = btn.getAttribute('data-reg-modal')!;
      const modal = document.getElementById(modalId)!;
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  document.querySelectorAll('.reg-modal').forEach((modalEl) => {
    const modal = modalEl as HTMLElement;
    modal.querySelector('.reg-modal-backdrop')!.addEventListener('click', () => closeRegModal(modal));
    modal.querySelector('.reg-modal-close')!.addEventListener('click', () => closeRegModal(modal));
  });

  function closeRegModal(modal: HTMLElement) {
    modal.classList.remove('open');
    (document.body.style as any).overflow = '';
  }

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const open = document.querySelector<HTMLElement>('.reg-modal.open');
    if (open) closeRegModal(open);
  });

  syncEventAccordions();
</script>
