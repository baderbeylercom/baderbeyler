---
import { getSiteData } from '../../lib/site-data';

const { heroContent } = await getSiteData();
const heroPanelStyle = `--hero-right-panel-width:${heroContent.appearance.rightPanelWidth}px;--hero-right-title-size:${heroContent.appearance.rightTitleSize}rem;--hero-right-body-size:${heroContent.appearance.rightBodySize}rem;`;
---

<section class="hero snap-section" id="home">
  <div class="hero-tone-layer" id="heroTone" aria-hidden="true"></div>
  <div class="hero-bg-text">{heroContent.bgText}</div>
  <div class="hero-line"></div>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="hero-left">
    <p class="hero-tag">{heroContent.eyebrow}</p>
    <h1 class="hero-title" set:html={heroContent.title}></h1>
    <p class="hero-desc">{heroContent.description}</p>
    <button type="button" class="hero-cta" id="heroCtaBtn">
      {heroContent.ctaLabel}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </button>
  </div>

  <div class="hero-person" id="heroPerson">
    <div class="hero-base" aria-hidden="true"></div>
    <img src={heroContent.heroImage} alt={heroContent.heroImageAlt} />
  </div>

  <div class="hero-focus-portrait" id="heroFocusPortrait" aria-hidden="true">
    <img src={heroContent.focusImage} alt={heroContent.focusImageAlt} />
  </div>

  <div class="hero-right" style={heroPanelStyle}>
    <p class="hero-right-tag">{heroContent.rightEyebrow}</p>
    <h2 class="hero-right-title" set:html={heroContent.rightTitle}></h2>
    <p class="hero-right-text" set:html={heroContent.rightText}></p>
    <div class="hero-right-stats">
      {
        heroContent.stats.map((item) => (
          <div class="hero-stat">
            <div class="stat-number">{item.value}</div>
            <div class="stat-label">{item.label}</div>
          </div>
        ))
      }
    </div>
    <div class="editor-resize-handle editor-resize-handle--hero-panel" data-editor-resize="hero-panel" aria-hidden="true"></div>
  </div>
</section>

<!-- Ön Görüşme Modal -->
<div id="ongorusme-modal" class="og-modal" role="dialog" aria-modal="true" aria-label="Ücretsiz Ön Görüşme">
  <div class="og-backdrop"></div>
  <div class="og-content">
    <button class="og-close" aria-label="Kapat">&#x2715;</button>
    <div class="og-header">
      <p class="og-eyebrow">Ücretsiz Ön Görüşme</p>
      <h3 class="og-title">Sizin için <em>buradayız</em></h3>
      <p class="og-desc">Nutrigenetik danışmanlık hakkında merak ettiklerinizi konuşmak için ücretsiz ön görüşme talep edin.</p>
    </div>
    <form class="og-form" id="ogForm">
      <div class="og-row">
        <div class="og-group">
          <label for="ogName">Ad Soyad</label>
          <input id="ogName" type="text" placeholder="Adınız Soyadınız" required />
        </div>
        <div class="og-group">
          <label for="ogEmail">E-posta</label>
          <input id="ogEmail" type="email" placeholder="ornek@mail.com" required />
        </div>
      </div>
      <div class="og-row">
        <div class="og-group">
          <label for="ogPhone">Telefon</label>
          <input id="ogPhone" type="tel" placeholder="+90 5XX XXX XX XX" />
        </div>
      </div>
      <div class="og-group">
        <label>Görüşme Türü</label>
        <div class="og-type-group">
          <label class="og-type-option">
            <input type="radio" name="ogMeetingType" value="online" required />
            <span>Online</span>
          </label>
          <label class="og-type-option">
            <input type="radio" name="ogMeetingType" value="yuzyuze" />
            <span>Yüz Yüze</span>
          </label>
        </div>
        <p class="og-helper" id="ogScheduleHint">Önce görüşme türünü seçin.</p>
      </div>
      <div class="og-row">
        <div class="og-group">
          <label for="ogDate">Randevu Tarihi</label>
          <input id="ogDate" type="date" required disabled />
        </div>
        <div class="og-group">
          <label for="ogTime">Randevu Saati</label>
          <select id="ogTime" required disabled>
            <option value="">Önce tarih seçin</option>
          </select>
        </div>
      </div>
      <div class="og-group">
        <label for="ogMessage">Mesajınız</label>
        <textarea id="ogMessage" placeholder="Bize bir şey iletmek ister misiniz?"></textarea>
      </div>
      <button class="og-submit" type="submit" id="ogSubmitBtn" disabled>Ön Görüşme Talep Et →</button>
    </form>
  </div>
</div>

<style>
  #heroCtaBtn {
    cursor: pointer;
  }

  .og-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .og-modal.open {
    pointer-events: auto;
    opacity: 1;
  }

  .og-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.75);
    cursor: pointer;
  }

  .og-content {
    position: relative;
    z-index: 1;
    background: #f8f5f1;
    border-radius: 1.25rem;
    padding: 2.5rem;
    max-width: min(92vw, 620px);
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    transform: translateY(24px) scale(0.97);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .og-modal.open .og-content {
    transform: translateY(0) scale(1);
  }

  .og-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    color: #888;
    transition: color 0.2s;
  }
  .og-close:hover { color: #111; }

  .og-header { margin-bottom: 1.5rem; }
  .og-eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 0.4rem;
  }
  .og-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 1.25;
  }
  .og-desc { font-size: 0.93rem; opacity: 0.65; line-height: 1.65; }

  .og-form { display: flex; flex-direction: column; gap: 1rem; }

  .og-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 520px) { .og-row { grid-template-columns: 1fr; } }

  .og-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .og-group label {
    font-size: 0.8rem;
    font-weight: 500;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .og-group input,
  .og-group select,
  .og-group textarea {
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 8px;
    padding: 0.65rem 0.9rem;
    font-size: 0.93rem;
    background: rgba(255,255,255,0.85);
    font-family: inherit;
    color: inherit;
    outline: none;
    transition: border-color 0.2s;
  }
  .og-group input:focus,
  .og-group select:focus,
  .og-group textarea:focus { border-color: rgba(0,0,0,0.35); }
  .og-group textarea { min-height: 80px; resize: vertical; }

  .og-group input:disabled,
  .og-group select:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    background: rgba(239, 239, 239, 0.75);
  }

  .og-type-group { display: flex; gap: 0.65rem; }
  .og-type-option {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    font-size: 0.93rem;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(0,0,0,0.15);
    border-radius: 8px;
    background: rgba(255,255,255,0.85);
    transition: border-color 0.2s, background 0.2s;
    user-select: none;
  }
  .og-type-option input[type="radio"] { accent-color: #3b1f55; }
  .og-type-option:has(input:checked) {
    border-color: #3b1f55;
    background: rgba(59,31,85,0.06);
  }

  .og-helper {
    font-size: 0.78rem;
    line-height: 1.5;
    color: #6b5c51;
    opacity: 0.9;
  }

  .og-submit {
    margin-top: 0.25rem;
    padding: 0.85rem 1.5rem;
    background: #161313;
    color: #f8f5f1;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.2s;
    align-self: stretch;
  }
  .og-submit:hover { opacity: 0.85; }
  .og-submit:disabled { opacity: 0.35; cursor: not-allowed; }
</style>

<script>
  const ogModal = document.getElementById('ongorusme-modal')!;
  const ogDateInput = document.getElementById('ogDate') as HTMLInputElement;
  const ogTimeInput = document.getElementById('ogTime') as HTMLSelectElement;
  const ogSubmitBtn = document.getElementById('ogSubmitBtn') as HTMLButtonElement;
  const ogScheduleHint = document.getElementById('ogScheduleHint') as HTMLParagraphElement;
  const ogMeetingTypeInputs = [
    ...document.querySelectorAll<HTMLInputElement>('input[name="ogMeetingType"]'),
  ];

  const SCHEDULE_RULES = {
    online: {
      allowedDays: [1, 2, 4, 5],
      timeSlots: [
        '10:00',
        '10:30',
        '11:00',
        '11:30',
        '12:00',
        '12:30',
        '13:00',
        '13:30',
        '14:00',
        '14:30',
        '15:00',
        '15:30',
        '16:00',
        '16:30',
        '17:00',
      ],
      hint: 'Online gorusmeler Pazartesi, Sali, Persembe ve Cuma gunleri 10:00-17:00 arasinda her 30 dakikada bir planlanir.',
    },
    yuzyuze: {
      allowedDays: [3],
      timeSlots: [
        '09:00',
        '10:00',
        '11:00',
        '12:00',
        '13:00',
        '14:00',
        '15:00',
        '16:00',
        '17:00',
        '18:00',
      ],
      hint: 'Yuz yuze gorusmeler yalnizca Carsamba gunleri 09:00-18:00 arasinda her saat basi planlanir.',
    },
  } as const;

  const today = new Date().toISOString().split('T')[0];
  ogDateInput.min = today;

  const formatDateValue = (date: Date) => {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  };

  const getSelectedMeetingType = () =>
    ogMeetingTypeInputs.find((input) => input.checked)?.value as keyof typeof SCHEDULE_RULES | undefined;

  const getNextAllowedDate = (meetingType: keyof typeof SCHEDULE_RULES) => {
    const candidate = new Date();
    candidate.setHours(0, 0, 0, 0);

    for (let offset = 0; offset < 21; offset += 1) {
      const next = new Date(candidate);
      next.setDate(candidate.getDate() + offset);
      if (SCHEDULE_RULES[meetingType].allowedDays.includes(next.getDay())) {
        return formatDateValue(next);
      }
    }

    return today;
  };

  const populateTimeSlots = (meetingType: keyof typeof SCHEDULE_RULES | undefined) => {
    ogTimeInput.innerHTML = '';

    if (!meetingType || !ogDateInput.value) {
      ogTimeInput.innerHTML = '<option value="">Once tarih secin</option>';
      ogTimeInput.disabled = true;
      return;
    }

    ogTimeInput.disabled = false;
    ogTimeInput.innerHTML = '<option value="">Saat secin</option>';
    const now = new Date();
    const selectedDate = new Date(`${ogDateInput.value}T00:00:00`);
    const isToday = ogDateInput.value === formatDateValue(now);
    const availableSlots = SCHEDULE_RULES[meetingType].timeSlots.filter((slot) => {
      if (!isToday) return true;
      const [hours, minutes] = slot.split(':').map(Number);
      const slotDate = new Date(selectedDate);
      slotDate.setHours(hours, minutes, 0, 0);
      return slotDate.getTime() > now.getTime();
    });

    if (!availableSlots.length) {
      ogTimeInput.innerHTML = '<option value="">Bu tarih icin uygun saat kalmadi</option>';
      ogTimeInput.disabled = true;
      return;
    }

    availableSlots.forEach((slot) => {
      const option = document.createElement('option');
      option.value = slot;
      option.textContent = slot;
      ogTimeInput.append(option);
    });
  };

  const validateSelectedDate = () => {
    const meetingType = getSelectedMeetingType();
    if (!meetingType || !ogDateInput.value) return;

    const selectedDate = new Date(`${ogDateInput.value}T00:00:00`);
    const isAllowed = SCHEDULE_RULES[meetingType].allowedDays.includes(selectedDate.getDay());

    if (!isAllowed) {
      ogDateInput.value = '';
      ogTimeInput.value = '';
      ogTimeInput.disabled = true;
      ogTimeInput.innerHTML = '<option value="">Uygun tarih secin</option>';
      ogDateInput.setCustomValidity('Sectiginiz gorusme turu icin bu tarih uygun degil.');
      ogDateInput.reportValidity();
      return false;
    }

    ogDateInput.setCustomValidity('');
    return true;
  };

  const updateSubmitState = () => {
    ogSubmitBtn.disabled = !(getSelectedMeetingType() && ogDateInput.value && ogTimeInput.value);
  };

  const applyMeetingType = () => {
    const meetingType = getSelectedMeetingType();

    ogDateInput.value = '';
    ogTimeInput.value = '';

    if (!meetingType) {
      ogDateInput.disabled = true;
      ogTimeInput.disabled = true;
      ogTimeInput.innerHTML = '<option value="">Once tarih secin</option>';
      ogScheduleHint.textContent = 'Once gorusme turunu secin.';
      updateSubmitState();
      return;
    }

    ogDateInput.disabled = false;
    ogDateInput.min = getNextAllowedDate(meetingType);
    ogScheduleHint.textContent = SCHEDULE_RULES[meetingType].hint;
    ogTimeInput.innerHTML = '<option value="">Once tarih secin</option>';
    ogTimeInput.disabled = true;
    updateSubmitState();
  };

  ogMeetingTypeInputs.forEach((input) => {
    input.addEventListener('change', applyMeetingType);
  });

  ogDateInput.addEventListener('change', () => {
    const isValid = validateSelectedDate();
    populateTimeSlots(isValid ? getSelectedMeetingType() : undefined);
    updateSubmitState();
  });

  ogTimeInput.addEventListener('change', updateSubmitState);

  document.getElementById('heroCtaBtn')!.addEventListener('click', () => {
    ogModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  ogModal.querySelector('.og-backdrop')!.addEventListener('click', closeOgModal);
  ogModal.querySelector('.og-close')!.addEventListener('click', closeOgModal);

  function closeOgModal() {
    ogModal.classList.remove('open');
    (document.body.style as any).overflow = '';
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && ogModal.classList.contains('open')) closeOgModal();
  });
</script>
