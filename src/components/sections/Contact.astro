---
import { getSiteData } from '../../lib/site-data';

const { contactContent } = await getSiteData();
const ap = contactContent.appearance;
const contactStyle = `--contact-title-size:${ap.titleSize}rem;--contact-body-size:${ap.bodySize}rem;--section-padding-y:${ap.paddingY}rem;`;
---

<section class="section contact snap-section" id="contact" style={contactStyle}>
  <div class="contact-info reveal-left">
    <p class="section-tag">{contactContent.eyebrow}</p>
    <h2 class="section-title" set:html={contactContent.title}></h2>
    <p class="contact-intro">
      {contactContent.intro}
    </p>

    <div class="contact-detail">
      <div class="contact-detail-icon">📍</div>
      <div>
        <h4>Adres</h4>
        <p>{contactContent.address}</p>
      </div>
    </div>

    <div class="contact-detail">
      <div class="contact-detail-icon">📧</div>
      <div>
        <h4>E-posta</h4>
        <p>
          <a href={`mailto:${contactContent.email}`}>{contactContent.email}</a>
        </p>
      </div>
    </div>

    <div class="contact-detail">
      <div class="contact-detail-icon">📱</div>
      <div>
        <h4>Telefon</h4>
        <p>
          <a href={`tel:${contactContent.phone.replaceAll(' ', '')}`}>
            {contactContent.phone}
          </a>
        </p>
      </div>
    </div>

    <div class="contact-detail">
      <div class="contact-detail-icon">⏰</div>
      <div>
        <h4>Çalışma Saatleri</h4>
        <p>{contactContent.hours}</p>
      </div>
    </div>

    <div class="social-links">
      {
        contactContent.socialLinks.map((item) => (
          <a href={item.href} class="social-link" aria-label={item.label}>
            {item.shortLabel}
          </a>
        ))
      }
    </div>
  </div>

  <div class="contact-form-wrapper reveal-right">
    <div class="form-row">
      <div class="form-group">
        <label for="fullName">Ad Soyad</label>
        <input id="fullName" type="text" placeholder="Adınız Soyadınız" />
      </div>
      <div class="form-group">
        <label for="emailAddress">E-posta</label>
        <input id="emailAddress" type="email" placeholder="ornek@mail.com" />
      </div>
    </div>

    <div class="form-group">
      <label for="contactTopic">Konu</label>
      <select id="contactTopic">
        <option value="">Konu Seçin</option>
        {
          contactContent.formTopics.map((topic) => (
            <option>{topic}</option>
          ))
        }
      </select>
    </div>

    <div class="form-group">
      <label for="contactMessage">Mesajınız</label>
      <textarea id="contactMessage" placeholder="Mesajınızı yazın..."></textarea>
    </div>

    <button class="form-submit" type="button">Gönder</button>
    <div class="editor-resize-handle editor-resize-handle--contact-form" data-editor-resize="contact-form-height" aria-hidden="true"></div>
  </div>
</section>
