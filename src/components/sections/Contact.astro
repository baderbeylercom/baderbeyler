---
import { getSiteData } from '../../lib/site-data';

const { contactContent } = await getSiteData();
const ap = contactContent.appearance;
const contactStyle = `--contact-title-size:${ap.titleSize}rem;--contact-body-size:${ap.bodySize}rem;--section-padding-y:${ap.paddingY}rem;`;
---

<section class="section contact snap-section" id="contact" style={contactStyle}>
  <div class="contact-info reveal-left">
    <p class="section-tag">{contactContent.eyebrow}</p>
    <h2 class="section-title" set:html={contactContent.title}></h2>
    <p class="contact-intro">
      {contactContent.intro}
    </p>

    <div class="contact-detail">
      <div class="contact-detail-icon">📍</div>
      <div>
        <h4>Adres</h4>
        <p>{contactContent.address}</p>
      </div>
    </div>

    <div class="contact-detail">
      <div class="contact-detail-icon">📧</div>
      <div>
        <h4>E-posta</h4>
        <p>
          <a href={`mailto:${contactContent.email}`}>{contactContent.email}</a>
        </p>
      </div>
    </div>

    <div class="contact-detail">
      <div class="contact-detail-icon">⏰</div>
      <div>
        <h4>Çalışma Saatleri</h4>
        <p>{contactContent.hours}</p>
      </div>
    </div>

    <div class="social-links">
      {
        contactContent.socialLinks.map((item) => (
          <a href={item.href} class="social-link" aria-label={item.label} target="_blank" rel="noreferrer">
            {
              item.label === 'Instagram' ? (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
                  <circle cx="12" cy="12" r="4.1"></circle>
                  <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"></circle>
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.8 9.2v7.9"></path>
                  <path d="M6.8 6.5a.9.9 0 1 1 0 1.8a.9.9 0 0 1 0-1.8Z"></path>
                  <path d="M10.8 9.2v7.9"></path>
                  <path d="M10.8 12.6c0-2 1.2-3.4 3-3.4s2.9 1.4 2.9 3.4v4.5"></path>
                </svg>
              )
            }
          </a>
        ))
      }
    </div>
  </div>

  <div class="contact-form-wrapper reveal-right">
    <div class="contact-concierge-panel">
      <div class="contact-concierge-copy">
        <p class="contact-concierge-tag">Concierge Akışı</p>
        <h3>İlk temastan planlamaya uzanan daha güvenli bir başlangıç</h3>
        <p>
          Danışmanlık, seminer ve iş birliği taleplerinizi kısa bir çerçevede iletin; uygun yönlendirme
          ve sonraki adımları netleştirelim.
        </p>
      </div>
      <div class="contact-concierge-points">
        <div class="contact-concierge-point">
          <span>01</span>
          <strong>Talep çerçevesi</strong>
          <p>İhtiyacınızı, hedefinizi ve iletişim konunuzu kısa biçimde aktarın.</p>
        </div>
        <div class="contact-concierge-point">
          <span>02</span>
          <strong>Ön değerlendirme</strong>
          <p>Size uygun görüşme tipi, kapsam ve iş birliği yolu belirlenir.</p>
        </div>
        <div class="contact-concierge-point">
          <span>03</span>
          <strong>Net geri dönüş</strong>
          <p>Uygun zamanlama ve sonraki adımlar şeffaf biçimde paylaşılır.</p>
        </div>
      </div>
    </div>

    <div class="contact-form-assurance">
      <div class="contact-assurance-item">
        <span class="contact-assurance-label">Geri Dönüş</span>
        <strong>{contactContent.hours}</strong>
      </div>
      <div class="contact-assurance-item">
        <span class="contact-assurance-label">Kapsam</span>
        <strong>Bireysel, kurumsal ve iş birliği talepleri</strong>
      </div>
    </div>

    <form id="contactForm">
      <div class="contact-form-panel">
        <div class="form-row">
          <div class="form-group">
            <label for="fullName">Ad Soyad</label>
            <input id="fullName" name="name" type="text" placeholder="Adınız Soyadınız" required />
          </div>
          <div class="form-group">
            <label for="emailAddress">E-posta</label>
            <input id="emailAddress" name="email" type="email" placeholder="ornek@mail.com" required />
          </div>
        </div>

        <div class="form-group">
          <label for="contactTopic">Konu</label>
          <select id="contactTopic" name="topic">
            <option value="">Konu Seçin</option>
            {
              contactContent.formTopics.map((topic) => (
                <option>{topic}</option>
              ))
            }
          </select>
        </div>

        <div class="form-group">
          <label for="contactMessage">Mesajınız</label>
          <textarea id="contactMessage" name="message" placeholder="Mesajınızı yazın..." required></textarea>
        </div>
      </div>

      <button class="form-submit" type="submit">Gönder</button>
    </form>
    <div class="editor-resize-handle editor-resize-handle--contact-form" data-editor-resize="contact-form-height" aria-hidden="true"></div>
  </div>
</section>
