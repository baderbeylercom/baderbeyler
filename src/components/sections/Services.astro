---
import { getSiteData } from '../../lib/site-data';

const { servicesContent } = await getSiteData();
const ap = servicesContent.appearance;
const servicesStyle = `--services-title-size:${ap.titleSize}rem;--services-card-title-size:${ap.cardTitleSize}rem;--services-card-body-size:${ap.cardBodySize}rem;--section-padding-y:${ap.paddingY}rem;--services-grid-gap:${ap.gridGap}rem;`;

const modalItems = servicesContent.items.filter(
  (item: any) => Array.isArray(item.detailImages) && item.detailImages.length > 0
);
---

<section class="section services snap-section" id="services" style={servicesStyle}>
  <div class="services-header reveal">
    <p class="section-tag">{servicesContent.eyebrow}</p>
    <h2 class="section-title" set:html={servicesContent.title}></h2>
  </div>

  <div class="services-grid">
    {
      servicesContent.items.map((item: any, index: number) => {
        const hasGallery = Array.isArray(item.detailImages) && item.detailImages.length > 0;
        const modalId = `modal-${index}`;
        return (
          <div class="service-card reveal" style={`transition-delay:.${index + 1}s`}>
            <div class="service-icon">{item.icon}</div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            {hasGallery ? (
              <button
                type="button"
                class="service-link service-galeri-btn"
                data-modal={modalId}
              >Detaylı Bilgi →</button>
            ) : (
              <a href={index === 0 ? '/nutrigenetik' : '#contact'} class="service-link">Detaylı Bilgi →</a>
            )}
          </div>
        );
      })
    }
  </div>

  <div class="photo-marquee">
    <div class="marquee-track">
      {[...servicesContent.marqueeImages, ...servicesContent.marqueeImages].map((src: string) => (
        <div class="marquee-item">
          <img src={src} alt="" loading="lazy" />
        </div>
      ))}
    </div>
    <div class="marquee-overlay-text">
      SAĞLIK · YAŞAM · DÖNÜŞÜM · SAĞLIK · YAŞAM · DÖNÜŞÜM
    </div>
  </div>
</section>

{modalItems.map((item: any) => {
  const itemIndex = servicesContent.items.indexOf(item);
  const modalId = `modal-${itemIndex}`;
  return (
    <div id={modalId} class="svc-modal" role="dialog" aria-modal="true" aria-label={item.title}>
      <div class="svc-modal-backdrop"></div>
      <div class="svc-modal-content">
        <button class="svc-modal-close" aria-label="Kapat">&#x2715;</button>
        <div class="svc-slider">
          {item.detailImages.map((src: string, i: number) => (
            <div class={`svc-slide${i === 0 ? ' active' : ''}`}>
              <img src={src} alt={`${item.title} ${i + 1}`} />
            </div>
          ))}
        </div>
        <div class="svc-nav">
          <button class="svc-prev" aria-label="Onceki">&#8592;</button>
          <span class="svc-counter"><span class="svc-current">1</span> / {item.detailImages.length}</span>
          <button class="svc-next" aria-label="Sonraki">&#8594;</button>
        </div>
      </div>
    </div>
  );
})}

<style>
  .service-galeri-btn {
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
    padding: 0;
    text-align: left;
  }

  .svc-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }
  .svc-modal.open { display: flex; }

  .svc-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.82);
    cursor: pointer;
  }

  .svc-modal-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: min(90vw, 960px);
    width: 100%;
  }

  .svc-modal-close {
    position: absolute;
    top: -2.5rem;
    right: 0;
    background: none;
    border: none;
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .svc-modal-close:hover { opacity: 1; }

  .svc-slider { width: 100%; }

  .svc-slide { display: none; }
  .svc-slide.active { display: block; }
  .svc-slide img {
    width: 100%;
    height: auto;
    border-radius: 0.75rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    display: block;
  }

  .svc-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    color: #fff;
  }

  .svc-prev, .svc-next {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .svc-prev:hover, .svc-next:hover { background: rgba(255,255,255,0.3); }

  .svc-counter {
    font-size: 1rem;
    letter-spacing: 0.05em;
    min-width: 4rem;
    text-align: center;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.service-galeri-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modalId = btn.getAttribute('data-modal')!;
      const modal = document.getElementById(modalId)!;
      openModal(modal);
    });
  });

  document.querySelectorAll('.svc-modal').forEach((modalEl) => {
    const modal = modalEl as HTMLElement;
    const slides = modal.querySelectorAll<HTMLElement>('.svc-slide');
    const currentEl = modal.querySelector<HTMLElement>('.svc-current')!;
    let current = 0;

    function show(n: number) {
      slides[current].classList.remove('active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
      currentEl.textContent = String(current + 1);
    }

    (modal as any)._show = show;

    modal.querySelector('.svc-modal-backdrop')!.addEventListener('click', () => closeModal(modal));
    modal.querySelector('.svc-modal-close')!.addEventListener('click', () => closeModal(modal));
    modal.querySelector('.svc-prev')!.addEventListener('click', () => show(current - 1));
    modal.querySelector('.svc-next')!.addEventListener('click', () => show(current + 1));
  });

  function openModal(modal: HTMLElement) {
    (modal as any)._show(0);
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(modal: Element) {
    modal.classList.remove('open');
    (document.body.style as any).overflow = '';
  }

  document.addEventListener('keydown', (e) => {
    const open = document.querySelector<HTMLElement>('.svc-modal.open');
    if (!open) return;
    if (e.key === 'Escape') closeModal(open);
  });
</script>
