---
interface Props {
  id: string;
  tag: string;
  title: string;
  paragraphs: string[];
  note: string;
  image: string;
  imageAlt: string;
  reverse?: boolean;
  appearance?: { titleSize?: number; bodySize?: number };
}

const { id, tag, title, paragraphs, note, image, imageAlt, reverse = false, appearance } =
  Astro.props;
const storyStyle = appearance
  ? `--story-title-size:${appearance.titleSize ?? 4}rem;--story-body-size:${appearance.bodySize ?? 1.02}rem;--story-padding-y:${appearance.paddingY ?? 2}rem;--story-padding-bottom:${appearance.paddingBottom ?? 5.2}rem;`
  : '';
---

<section class:list={['motion-story', 'snap-section', { reverse }]} id={id} style={storyStyle}>
  <div class="story-shell">
    <div class="story-text">
      <p class="story-tag">{tag}</p>
      <h2 class="story-title" set:html={title}></h2>
      <div class="story-line"></div>
      {
        paragraphs.map((paragraph) => (
          <p class="story-copy">{paragraph}</p>
        ))
      }
      <div class="story-note">{note}</div>
    </div>
    <div class="story-media dynamic-photo">
      <div class="story-img-holder">
        <div class="story-frame"></div>
        <img src={image} alt={imageAlt} />
      </div>
    </div>
  </div>
</section>
