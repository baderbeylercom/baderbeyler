---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { getSiteData } from '../lib/site-data';

const { aboutContent, siteConfig } = await getSiteData();
---

<BaseLayout
  title={`Hakkımda | ${siteConfig.brandName}`}
  description="Bader Beyler hakkında — nutrigenetik danışmanlık, bilimsel yaklaşım ve uzmanlık alanları."
>
  <Navbar />

  <main>
    <!-- ÜST: Kapak Fotoğrafı -->
    <div class="hk-cover">
      <img
        src={aboutContent.images.main}
        alt={aboutContent.images.mainAlt}
        class="hk-cover-img"
      />
      <div class="hk-cover-overlay"></div>
    </div>

    <!-- ALT: İçerik -->
    <section class="hk-body">
      <p class="section-tag">{aboutContent.eyebrow}</p>
      <h1 class="hk-title">{aboutContent.title}</h1>

      <div class="hk-text">
        {aboutContent.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <div class="hk-stats">
        {
          aboutContent.stats.map((item) => (
            <div class="hk-stat">
              <div class="hk-stat-number">{item.value}</div>
              <div class="hk-stat-label">{item.label}</div>
            </div>
          ))
        }
      </div>

      <a href="/#contact" class="hk-cta">İletişime Geç →</a>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Kapak Fotoğrafı ── */
  .hk-cover {
    position: relative;
    width: 100%;
    height: min(70vw, 520px);
    overflow: hidden;
    background: var(--clr-warm);
  }

  @media (max-width: 768px) {
    .hk-cover {
      height: min(90vw, 420px);
      margin-top: 4rem; /* nav için boşluk */
    }
  }

  @media (min-width: 769px) {
    .hk-cover {
      margin-top: 5rem;
    }
  }

  .hk-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hk-cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(239, 242, 243, 0.85) 100%);
  }

  /* ── İçerik ── */
  .hk-body {
    max-width: min(820px, 100%);
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  @media (min-width: 769px) {
    .hk-body {
      padding: 4rem 3rem 6rem;
    }
  }

  .hk-title {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--clr-deep);
    line-height: 1.15;
    margin: 0.75rem 0 1.5rem;
  }

  .hk-text p {
    font-size: 1.05rem;
    color: #2e231d;
    line-height: 1.82;
    margin-bottom: 1.1rem;
    opacity: 0.96;
  }

  /* ── İstatistikler ── */
  .hk-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(44, 24, 16, 0.08);
  }

  @media (max-width: 480px) {
    .hk-stats {
      gap: 0.6rem;
      margin-top: 1.75rem;
      padding-top: 1.75rem;
    }
  }

  .hk-stat-number {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2.4rem);
    font-weight: 700;
    color: var(--clr-terracotta);
    line-height: 1;
  }

  .hk-stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: #43332b;
    opacity: 0.86;
    margin-top: 0.3rem;
  }

  /* ── CTA ── */
  .hk-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding: 0.9rem 2rem;
    background: linear-gradient(135deg, var(--clr-deep), #41576b);
    color: var(--clr-cream);
    text-decoration: none;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.3s;
  }

  .hk-cta:hover {
    background: linear-gradient(135deg, var(--clr-deep), var(--clr-terracotta));
    transform: translateY(-2px);
  }
</style>

<script>
  const nav = document.getElementById('nav');
  if (nav) window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 60), { passive: true });
</script>
