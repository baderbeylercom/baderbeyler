const presetNames = [
  { key: 'default', label: 'Varsayilan' },
  { key: 'cool', label: 'Serin Mavi' },
  { key: 'warm', label: 'Sicak Toprak' },
  { key: 'dark', label: 'Koyu Elegans' },
  { key: 'minimal', label: 'Minimal' },
];
---

<BaseLayout
  title={`Duzenleme Modu | ${siteData.siteConfig.brandName}`}
  description="Canli onizleme ile renkleri, arka planlari, blob katmanlarini, fotograf yerlesimlerini ve tipografi olceklerini dogrudan gorerek ayarlayabileceginiz duzenleme modu."
  bodyClass="visual-editor-page"
>
  <div class="editor-shell">
    <aside class="editor-sidebar">
      <div class="editor-panel">
        <!-- Header -->
        <p class="editor-eyebrow">Canli Duzenleme</p>
        <h1 class="editor-title">Visual Builder</h1>
        <p class="editor-copy">
          Renkler, yazilar, kart stilleri, fotograf filtreleri ve daha fazlasini canli onizleme ile ayarla. Fotograflari surukleyebilir, turuncu handle'lari cekerek kutulari ve gorsel alanlarini buyutup kucultebilirsin.
        </p>

        <!-- Search -->
        <div class="editor-search-wrap">
          <input
            type="search"
            class="editor-search"
            placeholder="Kontrol ara... (ornek: baslik, renk, kose)"
            data-editor-search
          />
        </div>

        <!-- Section Quick Nav -->
        <nav class="editor-nav" data-editor-nav>
          {controlGroups.map((group) => (
            <button type="button" class="editor-nav-pill" data-nav-target={group.id}>
              <span class="editor-nav-icon">{group.icon}</span>
              <span class="editor-nav-label">{group.title.split('—')[0].trim().substring(0, 12)}</span>
            </button>
          ))}
        </nav>

        <!-- Actions -->
        <div class="editor-actions">
          <div class="editor-actions-row">
            <button type="button" class="editor-button editor-button--icon" data-editor-undo title="Geri al">&#8617;</button>
            <button type="button" class="editor-button editor-button--icon" data-editor-redo title="Ileri al">&#8618;</button>
            <button type="button" class="editor-button" data-editor-reset>Varsayilanlara don</button>
            <button type="button" class="editor-button editor-button--dark" data-editor-copy>JSON kopyala</button>
          </div>
          <a class="editor-link" href="/" target="_blank" rel="noreferrer">Ana sayfayi ac &#8599;</a>
        </div>

        <!-- Presets -->
        <div class="editor-presets">
          <p class="editor-presets-label">Hazir Temalar</p>
          <div class="editor-presets-row">
            {presetNames.map((p) => (
              <button
                type="button"
                class={`editor-preset-btn ${p.key === 'default' ? 'is-active' : ''}`}
                data-preset={p.key}
              >
                {p.label}
              </button>
            ))}
          </div>
        </div>

        <!-- Control Groups (Accordion) -->
        {controlGroups.map((group) => (
          <section class="editor-group" id={`group-${group.id}`} data-group-id={group.id}>
            <button type="button" class="editor-group-toggle" data-toggle-group={group.id}>
              <div class="editor-group-head">
                <span class="editor-group-icon">{group.icon}</span>
                <div>
                  <h2>{group.title}</h2>
                  <p>{group.description}</p>
                </div>
              </div>
              <span class="editor-chevron">&#9662;</span>
            </button>

            <div class="editor-fields" data-group-fields={group.id}>
              {group.items.map((item) => (
                <label class="editor-field" data-field-label={item.label.toLowerCase()}>
                  <span>{item.label}</span>
                  {item.controlType === 'color' ? (
                    <div class="editor-inputs editor-inputs--color">
                      <input
                        class="editor-color"
                        type="color"
                        value={String(item.value)}
                        data-editor-path={item.path}
                        data-editor-control-type="color"
                      />
                      <input
                        class="editor-text"
                        type="text"
                        value={String(item.value)}
                        data-editor-path={item.path}
                        data-editor-control-type="color"
                      />
                    </div>
                  ) : (
                    <div class="editor-inputs">
                      <input
                        class="editor-range"
                        type="range"
                        min={item.min}
                        max={item.max}
                        step={item.step}
                        value={Number(item.value)}
                        data-editor-path={item.path}
                        data-editor-control-type="number"
                      />
                      <input
                        class="editor-number"
                        type="number"
                        min={item.min}
                        max={item.max}
                        step={item.step}
                        value={Number(item.value)}
                        data-editor-path={item.path}
                        data-editor-control-type="number"
                      />
                    </div>
                  )}
                </label>
              ))}
            </div>
          </section>
        ))}

        <!-- Output -->
        <section class="editor-group editor-group--output">
          <div class="editor-group-head" style="padding-left:0;">
            <div>
              <h2>Cikti</h2>
              <p>Bu JSON tarayicida saklanir. Kalici hale getirmek icin CMS'e veya dosyaya baglanabilir.</p>
            </div>
          </div>
          <textarea id="editorExport" class="editor-output" readonly></textarea>
          <p class="editor-status" id="editorStatus">Canli onizleme hazir.</p>
        </section>
      </div>
    </aside>

    <div class="editor-preview">
      <Navbar />
      <main>
        <Hero />
        <section class="motion-story-wrap">
          {siteData.motionStories.map((story) => (
            <MotionStory {...story} />
          ))}
        </section>
        <About />
        <Services />
        <Collaborations />
        <Events events={events} />
        <Blog posts={blogPosts} />
        <Newsletter />
        <Contact />
      </main>
      <Footer />
    </div>
  </div>

  <!-- Data -->
  <script id="visual-editor-defaults" type="application/json" set:html={JSON.stringify(editorDefaults)} />
  <script id="visual-editor-presets" type="application/json" set:html={JSON.stringify(themePresets)} />

  <!-- Runtime -->
  <script>
    const STORAGE_KEY = 'bader-visual-overrides-v1';
    const MAX_HISTORY = 60;

    const defaultsNode = document.getElementById('visual-editor-defaults');
    const presetsNode = document.getElementById('visual-editor-presets');
    const output = document.getElementById('editorExport') as HTMLTextAreaElement | null;
    const status = document.getElementById('editorStatus');
    const controls = [...document.querySelectorAll('[data-editor-path]')] as HTMLInputElement[];
    const resetButton = document.querySelector('[data-editor-reset]');
    const copyButton = document.querySelector('[data-editor-copy]');
    const undoButton = document.querySelector('[data-editor-undo]');
    const redoButton = document.querySelector('[data-editor-redo]');
    const searchInput = document.querySelector('[data-editor-search]') as HTMLInputElement | null;
    const draggableParts = [...document.querySelectorAll('[data-collab-drag], [data-editor-drag]')] as HTMLElement[];
    const resizableParts = [...document.querySelectorAll('[data-editor-resize]')] as HTMLElement[];
    const groupToggles = [...document.querySelectorAll('[data-toggle-group]')];
    const navPills = [...document.querySelectorAll('[data-nav-target]')];
    const presetButtons = [...document.querySelectorAll('[data-preset]')];
    const groups = [...document.querySelectorAll('[data-group-id]')] as HTMLElement[];

    // Helpers
    const parseJson = (value: string | null, fallback: any) => {
      try { return value ? JSON.parse(value) : fallback; } catch { return fallback; }
    };
    const clone = (v: any) => parseJson(JSON.stringify(v), {});
    const isFiniteNumber = (v: any): v is number => typeof v === 'number' && Number.isFinite(v);

    const mergeDeep = (base: any, extra: any): any => {
      if (!extra || typeof extra !== 'object') return base;
      Object.entries(extra).forEach(([key, value]) => {
        if (Array.isArray(value)) {
          base[key] = value.map((item: any, index: number) => {
            const source = Array.isArray(base[key]) && typeof base[key][index] === 'object' && base[key][index] !== null ? base[key][index] : {};
            return typeof item === 'object' && item !== null ? mergeDeep(clone(source), item) : item;
          });
          return;
        }
        if (value && typeof value === 'object') {
          const source = typeof base[key] === 'object' && base[key] !== null && !Array.isArray(base[key]) ? base[key] : {};
          base[key] = mergeDeep(clone(source), value);
          return;
        }
        base[key] = value;
      });
      return base;
    };

    const getPathValue = (obj: any, path: string) => path.split('.').reduce((r, p) => r?.[p], obj);
    const setPathValue = (obj: any, path: string, value: any) => {
      const parts = path.split('.');
      let cursor = obj;
      parts.forEach((part, i) => {
        if (i === parts.length - 1) { cursor[part] = value; return; }
        const next = parts[i + 1];
        const nextIsIdx = /^\d+$/.test(next);
        if (!(part in cursor) || cursor[part] === null) cursor[part] = nextIsIdx ? [] : {};
        cursor = cursor[part];
      });
    };

    const getNumericBounds = (path: string) => {
      const control = controls.find((item) => item.dataset.editorPath === path && item.dataset.editorControlType === 'number');
      const min = control?.min !== '' && control ? Number(control.min) : Number.NEGATIVE_INFINITY;
      const max = control?.max !== '' && control ? Number(control.max) : Number.POSITIVE_INFINITY;
      return {
        min: Number.isFinite(min) ? min : Number.NEGATIVE_INFINITY,
        max: Number.isFinite(max) ? max : Number.POSITIVE_INFINITY,
      };
    };

    const clampNumericValue = (path: string, value: number) => {
      const { min, max } = getNumericBounds(path);
      return Math.min(max, Math.max(min, value));
    };

    // State
    const defaults = parseJson(defaultsNode?.textContent ?? null, {});
    const presets = parseJson(presetsNode?.textContent ?? null, {});
    const storedState = parseJson(window.localStorage.getItem(STORAGE_KEY), null);
    let state = mergeDeep(clone(defaults), storedState ?? {});

    // History (undo/redo)
    let history: string[] = [JSON.stringify(state)];
    let historyIndex = 0;

    const pushHistory = () => {
      const snap = JSON.stringify(state);
      if (history[historyIndex] === snap) return;
      history = history.slice(0, historyIndex + 1);
      history.push(snap);
      if (history.length > MAX_HISTORY) history.shift();
      historyIndex = history.length - 1;
      updateUndoRedoState();
    };

    const updateUndoRedoState = () => {
      if (undoButton instanceof HTMLButtonElement) undoButton.disabled = historyIndex <= 0;
      if (redoButton instanceof HTMLButtonElement) redoButton.disabled = historyIndex >= history.length - 1;
    };

    const applyHistorySnapshot = (snap: string) => {
      state = parseJson(snap, clone(defaults));
      syncAllControls();
      broadcastState();
      writeOutput('Gecmis uyguland\u0131.');
    };

    // Sync
    const syncPathControls = (path: string) => {
      const val = getPathValue(state, path);
      controls.filter(c => c.dataset.editorPath === path).forEach(c => { c.value = String(val); });
    };

    const writeOutput = (msg: string) => {
      if (output) output.value = JSON.stringify(state, null, 2);
      if (status) status.textContent = msg;
    };

    const broadcastState = () => {
      window.localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      window.dispatchEvent(new CustomEvent('bader-visual-overrides-updated'));
      (window as any)['__baderApplyVisualOverrides']?.();
    };

    const persistState = (msg: string) => { broadcastState(); writeOutput(msg); };

    const syncAllControls = () => {
      [...new Set(controls.map(c => c.dataset.editorPath).filter(Boolean))].forEach(p => syncPathControls(p!));
      writeOutput('Canli onizleme hazir.');
    };

    // Controls binding
    controls.forEach(control => {
      control.addEventListener('input', () => {
        const path = control.dataset.editorPath;
        if (!path) return;
        const ct = control.dataset.editorControlType || 'number';
        const value = ct === 'number' ? Number(control.value) : control.value;
        setPathValue(state, path, value);
        syncPathControls(path);
        const label = control.closest('.editor-field')?.querySelector('span')?.textContent?.trim() || 'Ayar';
        persistState(`${label} guncellendi.`);
        pushHistory();
      });
    });

    // Accordion
    const collapsedGroups = new Set<string>();

    groupToggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const id = (toggle as HTMLElement).dataset.toggleGroup;
        if (!id) return;
        const fields = document.querySelector(`[data-group-fields="${id}"]`) as HTMLElement | null;
        const group = document.getElementById(`group-${id}`);
        if (!fields || !group) return;
        const isCollapsed = group.classList.toggle('is-collapsed');
        if (isCollapsed) collapsedGroups.add(id); else collapsedGroups.delete(id);
      });
    });

    // Search
    searchInput?.addEventListener('input', () => {
      const query = (searchInput.value || '').toLowerCase().trim();
      groups.forEach(group => {
        if (!query) {
          group.style.display = '';
          group.querySelectorAll('.editor-field').forEach(f => (f as HTMLElement).style.display = '');
          return;
        }
        const fields = [...group.querySelectorAll('.editor-field')] as HTMLElement[];
        let groupVisible = false;
        const groupTitle = group.querySelector('h2')?.textContent?.toLowerCase() || '';
        if (groupTitle.includes(query)) {
          group.style.display = '';
          fields.forEach(f => f.style.display = '');
          groupVisible = true;
        } else {
          fields.forEach(f => {
            const label = f.dataset.fieldLabel || '';
            const visible = label.includes(query);
            f.style.display = visible ? '' : 'none';
            if (visible) groupVisible = true;
          });
          group.style.display = groupVisible ? '' : 'none';
        }
        if (groupVisible && query) group.classList.remove('is-collapsed');
      });
    });

    // Nav pills
    navPills.forEach(pill => {
      pill.addEventListener('click', () => {
        const target = (pill as HTMLElement).dataset.navTarget;
        if (!target) return;
        const group = document.getElementById(`group-${target}`);
        if (group) {
          group.classList.remove('is-collapsed');
          group.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Presets
    presetButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const key = (btn as HTMLElement).dataset.preset;
        if (!key) return;
        if (key === 'default') {
          state = clone(defaults);
        } else {
          const preset = presets[key];
          if (preset) state = mergeDeep(clone(defaults), preset);
        }
        presetButtons.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        syncAllControls();
        persistState(`"${btn.textContent?.trim()}" teması uygulandi.`);
        pushHistory();
      });
    });

    // Undo / Redo
    undoButton?.addEventListener('click', () => {
      if (historyIndex <= 0) return;
      historyIndex--;
      applyHistorySnapshot(history[historyIndex]);
      updateUndoRedoState();
    });

    redoButton?.addEventListener('click', () => {
      if (historyIndex >= history.length - 1) return;
      historyIndex++;
      applyHistorySnapshot(history[historyIndex]);
      updateUndoRedoState();
    });

    // Reset
    resetButton?.addEventListener('click', () => {
      state = clone(defaults);
      window.localStorage.removeItem(STORAGE_KEY);
      syncAllControls();
      broadcastState();
      writeOutput('Varsayilan tasarima donuldu.');
      presetButtons.forEach(b => b.classList.remove('is-active'));
      presetButtons[0]?.classList.add('is-active');
      pushHistory();
    });

    // Copy JSON
    copyButton?.addEventListener('click', async () => {
      if (!output) return;
      try {
        await navigator.clipboard.writeText(output.value);
        writeOutput('JSON panoya kopyalandi.');
      } catch {
        output.focus();
        output.select();
        writeOutput('Kopyalama basarisiz, JSON secildi.');
      }
    });

    // Direct manipulation on preview: drag and resize
    let dragState: any = null;

    const updateNumericPath = (path: string, value: number) => {
      const next = clampNumericValue(path, value);
      setPathValue(state, path, next);
      syncPathControls(path);
      return next;
    };

    const startEditorInteraction = (pe: PointerEvent, config: any) => {
      dragState = {
        ...config,
        startX: pe.clientX,
        startY: pe.clientY,
      };
      document.body.classList.add(config.mode === 'resize' ? 'is-resizing-editor' : 'is-dragging-editor');
      if (status) status.textContent = config.startMessage ?? `${config.label} duzenleniyor...`;
      window.addEventListener('pointermove', handleDragMove);
      window.addEventListener('pointerup', stopDrag);
    };

    const handleDragMove = (e: PointerEvent) => {
      if (!dragState) return;
      dragState.onMove?.(e);
      broadcastState();
    };

    const stopDrag = () => {
      if (!dragState) return;
      const label = dragState.label;
      dragState = null;
      document.body.classList.remove('is-dragging-editor', 'is-resizing-editor');
      window.removeEventListener('pointermove', handleDragMove);
      window.removeEventListener('pointerup', stopDrag);
      writeOutput(`${label} guncellendi.`);
      pushHistory();
    };

    draggableParts.forEach((part) => {
      part.addEventListener('pointerdown', (e: Event) => {
        const pe = e as PointerEvent;
        if (!(part instanceof HTMLElement)) return;

        const editorDrag = part.dataset.editorDrag;
        const collabKind = part.dataset.collabDrag;

        if (editorDrag === 'about-main' || editorDrag === 'about-accent') {
          pe.preventDefault();
          const stack = part.closest('.about-photo-stack') as HTMLElement | null;
          if (!stack) return;
          const stackRect = stack.getBoundingClientRect();
          const isMain = editorDrag === 'about-main';
          const pathX = isMain ? 'about.mainPhotoLeft' : 'about.accentPhotoRight';
          const pathY = isMain ? 'about.mainPhotoTop' : 'about.accentPhotoBottom';
          const baseX = Number(getPathValue(state, pathX) ?? 0);
          const baseY = Number(getPathValue(state, pathY) ?? 0);
          const factorX = isMain ? 1 : -1;
          const factorY = isMain ? 1 : -1;

          startEditorInteraction(pe, {
            mode: 'drag',
            label: isMain ? 'About ana fotograf' : 'About kucuk fotograf',
            startMessage: `${isMain ? 'Ana fotograf' : 'Kucuk fotograf'} surukleniyor...`,
            onMove: (moveEvent: PointerEvent) => {
              const dxPercent = ((moveEvent.clientX - pe.clientX) / stackRect.width) * 100;
              const dyPercent = ((moveEvent.clientY - pe.clientY) / stackRect.height) * 100;
              const nx = updateNumericPath(pathX, Math.round((baseX + (dxPercent * factorX)) * 100) / 100);
              const ny = updateNumericPath(pathY, Math.round((baseY + (dyPercent * factorY)) * 100) / 100);
              if (status) status.textContent = `${isMain ? 'Ana fotograf' : 'Kucuk fotograf'} surukle... X ${nx.toFixed(1)}%, Y ${ny.toFixed(1)}%`;
            },
          });
          return;
        }

        if (collabKind) {
          const index = Number(part.dataset.collabIndex);
          if (!Number.isFinite(index)) return;
          pe.preventDefault();
          const base = collabKind === 'blob' ? 'blobOffset' : 'imageOffset';
          const xPath = `collaborations.items.${index}.design.${base}X`;
          const yPath = `collaborations.items.${index}.design.${base}Y`;
          const baseX = Number(getPathValue(state, xPath) ?? 0);
          const baseY = Number(getPathValue(state, yPath) ?? 0);

          startEditorInteraction(pe, {
            mode: 'drag',
            label: collabKind === 'blob' ? 'Blob katmani' : 'Fotograf',
            startMessage: `${collabKind === 'blob' ? 'Blob katmani' : 'Fotograf'} surukleniyor...`,
            onMove: (moveEvent: PointerEvent) => {
              const nx = updateNumericPath(xPath, Math.round(baseX + (moveEvent.clientX - pe.clientX)));
              const ny = updateNumericPath(yPath, Math.round(baseY + (moveEvent.clientY - pe.clientY)));
              if (status) status.textContent = `${collabKind === 'blob' ? 'Blob katmani' : 'Fotograf'} surukle... X ${nx}, Y ${ny}`;
            },
          });
        }
      });
    });

    resizableParts.forEach((part) => {
      part.addEventListener('pointerdown', (e: Event) => {
        const pe = e as PointerEvent;
        if (!(part instanceof HTMLElement)) return;
        pe.preventDefault();
        pe.stopPropagation();

        const resizeKind = part.dataset.editorResize;
        if (!resizeKind) return;

        if (resizeKind === 'hero-panel') {
          const path = 'hero.rightPanelWidth';
          const base = Number(getPathValue(state, path) ?? 480);
          startEditorInteraction(pe, {
            mode: 'resize',
            label: 'Hero paneli',
            startMessage: 'Hero panel genisligi ayarlaniyor...',
            onMove: (moveEvent: PointerEvent) => {
              const next = updateNumericPath(path, Math.round(base + (moveEvent.clientX - pe.clientX)));
              if (status) status.textContent = `Hero panel genisligi ${next}px`;
            },
          });
          return;
        }

        if (resizeKind === 'blog-image-ratio') {
          const path = 'cardStyles.blogImageRatio';
          const base = Number(getPathValue(state, path) ?? 1.6);
          startEditorInteraction(pe, {
            mode: 'resize',
            label: 'Blog gorseli',
            startMessage: 'Blog gorsel orani ayarlaniyor...',
            onMove: (moveEvent: PointerEvent) => {
              const delta = (moveEvent.clientY - pe.clientY) / 180;
              const next = updateNumericPath(path, Math.round((base - delta) * 100) / 100);
              if (status) status.textContent = `Blog gorsel orani ${next.toFixed(2)}`;
            },
          });
          return;
        }

        if (resizeKind === 'about-stack' || resizeKind === 'about-main' || resizeKind === 'about-accent') {
          const stack = part.closest('.about-photo-stack') as HTMLElement | null;
          if (!stack) return;
          const stackRect = stack.getBoundingClientRect();

          if (resizeKind === 'about-stack') {
            const path = 'about.stackHeight';
            const base = Number(getPathValue(state, path) ?? stackRect.height);
            startEditorInteraction(pe, {
              mode: 'resize',
              label: 'About fotograf alani',
              startMessage: 'Fotograf alani yuksekligi ayarlaniyor...',
              onMove: (moveEvent: PointerEvent) => {
                const next = updateNumericPath(path, Math.round(base + (moveEvent.clientY - pe.clientY)));
                if (status) status.textContent = `Fotograf alani yuksekligi ${next}px`;
              },
            });
            return;
          }

          const path = resizeKind === 'about-main' ? 'about.mainPhotoWidth' : 'about.accentPhotoWidth';
          const base = Number(getPathValue(state, path) ?? 50);
          startEditorInteraction(pe, {
            mode: 'resize',
            label: resizeKind === 'about-main' ? 'About ana fotograf' : 'About kucuk fotograf',
            startMessage: 'Fotograf boyutu ayarlaniyor...',
            onMove: (moveEvent: PointerEvent) => {
              const dxPercent = ((moveEvent.clientX - pe.clientX) / stackRect.width) * 100;
              const next = updateNumericPath(path, Math.round((base + dxPercent) * 100) / 100);
              if (status) status.textContent = `Fotograf genisligi ${next.toFixed(1)}%`;
            },
          });
          return;
        }

        if (resizeKind.startsWith('collab-')) {
          const index = Number(part.dataset.collabIndex);
          if (!Number.isFinite(index)) return;

          const imagePath = `collaborations.items.${index}.design.imageWidth`;
          const visualPath = `collaborations.items.${index}.design.visualHeight`;
          const blobWidthPath = `collaborations.items.${index}.design.blobWidth`;
          const blobHeightPath = `collaborations.items.${index}.design.blobHeight`;

          if (resizeKind === 'collab-image') {
            const base = Number(getPathValue(state, imagePath) ?? 188);
            startEditorInteraction(pe, {
              mode: 'resize',
              label: 'Partner fotografi',
              startMessage: 'Partner fotograf boyutu ayarlaniyor...',
              onMove: (moveEvent: PointerEvent) => {
                const next = updateNumericPath(imagePath, Math.round(base + (moveEvent.clientX - pe.clientX)));
                if (status) status.textContent = `Partner fotograf genisligi ${next}px`;
              },
            });
            return;
          }

          if (resizeKind === 'collab-visual') {
            const base = Number(getPathValue(state, visualPath) ?? 220);
            startEditorInteraction(pe, {
              mode: 'resize',
              label: 'Gorsel alan',
              startMessage: 'Gorsel alan yuksekligi ayarlaniyor...',
              onMove: (moveEvent: PointerEvent) => {
                const next = updateNumericPath(visualPath, Math.round(base + (moveEvent.clientY - pe.clientY)));
                if (status) status.textContent = `Gorsel alan yuksekligi ${next}px`;
              },
            });
            return;
          }

          if (resizeKind === 'collab-blob') {
            const baseW = Number(getPathValue(state, blobWidthPath) ?? 194);
            const baseH = Number(getPathValue(state, blobHeightPath) ?? 224);
            startEditorInteraction(pe, {
              mode: 'resize',
              label: 'Blob katmani',
              startMessage: 'Blob boyutu ayarlaniyor...',
              onMove: (moveEvent: PointerEvent) => {
                const nextW = updateNumericPath(blobWidthPath, Math.round(baseW + (moveEvent.clientX - pe.clientX)));
                const nextH = updateNumericPath(blobHeightPath, Math.round(baseH + (moveEvent.clientY - pe.clientY)));
                if (status) status.textContent = `Blob boyutu ${nextW}px × ${nextH}px`;
              },
            });
          }
        }

        if (resizeKind === 'event-card-height') {
          const card = part.closest('.event-card') as HTMLElement | null;
          const path = 'events.cardMinHeight';
          const base = Number(getPathValue(state, path) ?? Math.round(card?.getBoundingClientRect().height ?? 430));
          startEditorInteraction(pe, {
            mode: 'resize',
            label: 'Etkinlik karti',
            startMessage: 'Etkinlik karti yuksekligi ayarlaniyor...',
            onMove: (moveEvent: PointerEvent) => {
              const next = updateNumericPath(path, Math.round(base + (moveEvent.clientY - pe.clientY)));
              if (status) status.textContent = `Etkinlik karti min yuksekligi ${next}px`;
            },
          });
          return;
        }

        if (resizeKind === 'contact-form-height') {
          const form = part.closest('.contact-form-wrapper') as HTMLElement | null;
          const path = 'contact.formMinHeight';
          const base = Number(getPathValue(state, path) ?? Math.round(form?.getBoundingClientRect().height ?? 560));
          startEditorInteraction(pe, {
            mode: 'resize',
            label: 'Iletisim formu',
            startMessage: 'Iletisim form yuksekligi ayarlaniyor...',
            onMove: (moveEvent: PointerEvent) => {
              const next = updateNumericPath(path, Math.round(base + (moveEvent.clientY - pe.clientY)));
              if (status) status.textContent = `Iletisim formu min yuksekligi ${next}px`;
            },
          });
          return;
        }
      });
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
        e.preventDefault();
        (undoButton as HTMLElement)?.click();
      }
      if ((e.ctrlKey || e.metaKey) && (e.key === 'y' || (e.key === 'z' && e.shiftKey))) {
        e.preventDefault();
        (redoButton as HTMLElement)?.click();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
        e.preventDefault();
        searchInput?.focus();
      }
    });

    // Init
    syncAllControls();
    broadcastState();
    updateUndoRedoState();

    if (storedState) writeOutput('Onceki yerel ayarlar geri yuklendi.');
  </script>
</BaseLayout>
