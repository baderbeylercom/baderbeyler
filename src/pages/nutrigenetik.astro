---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
---

<BaseLayout
  title="BB Nutrigenetik Danışmanlık | Bader Beyler"
  description="BB Nutrigenetik Danışmanlık hizmet detayları"
>
  <Navbar />

  <main class="pdf-page">
    <div class="pdf-back-wrap">
      <a href="/#services" class="pdf-back">← Hizmetlere Dön</a>
    </div>

    <div class="pdf-layout">
      <!-- Sol: PDF Görüntüleyici -->
      <div class="pdf-left">
        <div class="pdf-viewer-wrap">
          <canvas id="pdfCanvas"></canvas>
        </div>
      </div>

      <!-- Sağ: Başlık + Form -->
      <div class="pdf-right">
        <div class="pdf-cta-block">
          <p class="section-tag">Ücretsiz Ön Görüşme</p>
          <h2>Sizin için <em>buradayız</em></h2>
          <p class="pdf-cta-desc">Nutrigenetik danışmanlık hakkında merak ettiklerinizi konuşmak için ücretsiz ön görüşme talep edin.</p>
        </div>

        <form class="pdf-form" id="pdfContactForm">
          <div class="pdf-form-group">
            <label for="pdfName">Ad Soyad</label>
            <input id="pdfName" type="text" placeholder="Adınız Soyadınız" required />
          </div>
          <div class="pdf-form-group">
            <label for="pdfEmail">E-posta</label>
            <input id="pdfEmail" type="email" placeholder="ornek@mail.com" required />
          </div>
          <div class="pdf-form-group">
            <label for="pdfPhone">Telefon</label>
            <input id="pdfPhone" type="tel" placeholder="+90 5XX XXX XX XX" />
          </div>
          <div class="pdf-form-group">
            <label for="pdfMessage">Mesajınız</label>
            <textarea id="pdfMessage" placeholder="Bize bir şey iletmek ister misiniz?"></textarea>
          </div>
          <button class="pdf-form-submit" type="submit">Ön Görüşme Talep Et →</button>
        </form>
      </div>
    </div>
  </main>

  <div class="pdf-controls-bar">
    <button id="prevPage" aria-label="Önceki sayfa">←</button>
    <span id="pageInfo">1 / 1</span>
    <button id="nextPage" aria-label="Sonraki sayfa">→</button>
  </div>

  <Footer />
</BaseLayout>

<script>
  import * as pdfjsLib from 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.min.mjs';

  pdfjsLib.GlobalWorkerOptions.workerSrc =
    'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.worker.min.mjs';

  const url = '/assets/pdfs/Genetik%20Panel.pdf';
  const canvas = document.getElementById('pdfCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const pageInfo = document.getElementById('pageInfo')!;
  const prevBtn = document.getElementById('prevPage')!;
  const nextBtn = document.getElementById('nextPage')!;

  let pdfDoc: any = null;
  let currentPage = 1;

  function getScale() {
    return window.innerWidth < 768 ? 0.8 : 1.1;
  }

  async function renderPage(num: number) {
    const page = await pdfDoc.getPage(num);
    const viewport = page.getViewport({ scale: getScale() });
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    await page.render({ canvasContext: ctx, viewport }).promise;
    pageInfo.textContent = `${num} / ${pdfDoc.numPages}`;
    prevBtn.toggleAttribute('disabled', num <= 1);
    nextBtn.toggleAttribute('disabled', num >= pdfDoc.numPages);
  }

  pdfjsLib.getDocument(url).promise.then((doc: any) => {
    pdfDoc = doc;
    renderPage(1);
  });

  prevBtn.addEventListener('click', () => { if (currentPage > 1) renderPage(--currentPage); });
  nextBtn.addEventListener('click', () => { if (currentPage < pdfDoc.numPages) renderPage(++currentPage); });
</script>

<style>
  .pdf-page {
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 5rem;
    background: var(--color-bg, #f8f5f1);
  }

  .pdf-back-wrap {
    max-width: 1200px;
    margin: 0 auto 2rem;
    padding: 0 2rem;
  }

  .pdf-back {
    font-size: 0.9rem;
    opacity: 0.55;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .pdf-back:hover { opacity: 1; }

  .pdf-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 3.5rem;
    align-items: start;
  }

  /* PDF Sol */
  #pdfCanvas {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.12);
    display: block;
  }

  .pdf-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .pdf-controls button {
    background: none;
    border: 1px solid currentColor;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    cursor: pointer;
    font-size: 1rem;
    opacity: 0.65;
    transition: opacity 0.2s;
  }

  .pdf-controls button:hover { opacity: 1; }
  .pdf-controls-bar {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: rgba(22, 19, 19, 0.88);
    color: #f8f5f1;
    border-radius: 999px;
    padding: 0.6rem 1.5rem;
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.2);
    z-index: 100;
  }

  .pdf-controls-bar button {
    background: none;
    border: none;
    color: inherit;
    font-size: 1.1rem;
    cursor: pointer;
    opacity: 0.75;
    transition: opacity 0.2s;
    padding: 0.2rem 0.4rem;
  }

  .pdf-controls-bar button:hover { opacity: 1; }
  .pdf-controls-bar button[disabled] { opacity: 0.2; cursor: default; }
  #pageInfo { font-size: 0.88rem; opacity: 0.7; min-width: 3.5rem; text-align: center; }

  /* Sağ Panel */
  .pdf-right {
    position: sticky;
    top: 7rem;
  }

  .pdf-cta-block {
    margin-bottom: 2rem;
  }

  .pdf-cta-block h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin: 0.5rem 0 0.75rem;
    line-height: 1.2;
  }

  .pdf-cta-desc {
    font-size: 0.95rem;
    opacity: 0.65;
    line-height: 1.7;
  }

  /* Form */
  .pdf-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: rgba(255,255,255,0.6);
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 16px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
  }

  .pdf-form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pdf-form-group label {
    font-size: 0.82rem;
    font-weight: 500;
    opacity: 0.65;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pdf-form-group input,
  .pdf-form-group textarea {
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.95rem;
    background: rgba(255,255,255,0.8);
    font-family: inherit;
    color: inherit;
    transition: border-color 0.2s;
    outline: none;
  }

  .pdf-form-group input:focus,
  .pdf-form-group textarea:focus {
    border-color: rgba(0,0,0,0.35);
  }

  .pdf-form-group textarea {
    min-height: 90px;
    resize: vertical;
  }

  .pdf-form-submit {
    margin-top: 0.25rem;
    padding: 0.85rem 1.5rem;
    background: #161313;
    color: #f8f5f1;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .pdf-form-submit:hover { opacity: 0.85; }

  /* Mobil */
  @media (max-width: 900px) {
    .pdf-layout {
      grid-template-columns: 1fr;
    }

    .pdf-right {
      position: static;
    }
  }
</style>
