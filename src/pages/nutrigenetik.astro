---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
---

<BaseLayout
  title="BB Nutrigenetik Danışmanlık | Bader Beyler"
  description="BB Nutrigenetik Danışmanlık hizmet detayları"
>
  <Navbar />

  <main class="pdf-page">
    <div class="pdf-back-wrap">
      <a href="/#services" class="pdf-back">← Hizmetlere Dön</a>
    </div>

    <div class="pdf-layout">
      <!-- Sol: PDF Görüntüleyici -->
      <div class="pdf-left">
        <div class="pdf-viewer-wrap">
          <canvas id="pdfCanvas"></canvas>
        </div>
      </div>

      <!-- Sağ: Başlık + Form -->
      <div class="pdf-right">
        <div class="pdf-cta-block">
          <p class="section-tag">Ücretsiz Ön Görüşme</p>
          <h2>Sizin için <em>buradayız</em></h2>
          <p class="pdf-cta-desc">Nutrigenetik danışmanlık hakkında merak ettiklerinizi konuşmak için ücretsiz ön görüşme talep edin.</p>
        </div>

        <form class="pdf-form" id="pdfContactForm">
          <div class="pdf-form-group">
            <label for="pdfName">Ad Soyad</label>
            <input id="pdfName" type="text" placeholder="Adınız Soyadınız" required />
          </div>
          <div class="pdf-form-group">
            <label for="pdfEmail">E-posta</label>
            <input id="pdfEmail" type="email" placeholder="ornek@mail.com" required />
          </div>
          <div class="pdf-form-group">
            <label for="pdfPhone">Telefon</label>
            <input id="pdfPhone" type="tel" placeholder="+90 5XX XXX XX XX" />
          </div>
          <div class="pdf-form-group">
            <label>Görüşme Türü</label>
            <div class="pdf-type-group">
              <label class="pdf-type-option">
                <input type="radio" name="meetingType" value="online" required />
                <span>Online</span>
              </label>
              <label class="pdf-type-option">
                <input type="radio" name="meetingType" value="yuzyuze" />
                <span>Yüz Yüze</span>
              </label>
            </div>
            <p class="pdf-helper" id="pdfScheduleHint">Önce görüşme türünü seçin.</p>
          </div>
          <div class="pdf-form-group">
            <label for="pdfDate">Randevu Tarihi</label>
            <input id="pdfDate" type="date" required disabled />
          </div>
          <div class="pdf-form-group">
            <label for="pdfTime">Randevu Saati</label>
            <select id="pdfTime" required disabled>
              <option value="">Önce tarih seçin</option>
            </select>
          </div>
          <div class="pdf-form-group">
            <label for="pdfMessage">Mesajınız</label>
            <textarea id="pdfMessage" placeholder="Bize bir şey iletmek ister misiniz?"></textarea>
          </div>
          <button class="pdf-form-submit" type="submit" id="pdfSubmitBtn" disabled>Ön Görüşme Talep Et →</button>
        </form>
      </div>
    </div>
  </main>

  <div class="pdf-controls-bar">
    <button id="prevPage" aria-label="Önceki sayfa">←</button>
    <span id="pageInfo">1 / 1</span>
    <button id="nextPage" aria-label="Sonraki sayfa">→</button>
  </div>

  <Footer />
</BaseLayout>

<script>
  import * as pdfjsLib from 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.min.mjs';

  pdfjsLib.GlobalWorkerOptions.workerSrc =
    'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.worker.min.mjs';

  const url = '/assets/pdfs/Genetik%20Panel.pdf';
  const canvas = document.getElementById('pdfCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const pageInfo = document.getElementById('pageInfo')!;
  const prevBtn = document.getElementById('prevPage')!;
  const nextBtn = document.getElementById('nextPage')!;

  let pdfDoc: any = null;
  let currentPage = 1;

  function getScale() {
    return window.innerWidth < 768 ? 0.8 : 1.1;
  }

  async function renderPage(num: number) {
    const page = await pdfDoc.getPage(num);
    const viewport = page.getViewport({ scale: getScale() });
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    await page.render({ canvasContext: ctx, viewport }).promise;
    pageInfo.textContent = `${num} / ${pdfDoc.numPages}`;
    prevBtn.toggleAttribute('disabled', num <= 1);
    nextBtn.toggleAttribute('disabled', num >= pdfDoc.numPages);
  }

  pdfjsLib.getDocument(url).promise.then((doc: any) => {
    pdfDoc = doc;
    renderPage(1);
  });

  prevBtn.addEventListener('click', () => { if (currentPage > 1) renderPage(--currentPage); });
  nextBtn.addEventListener('click', () => { if (currentPage < pdfDoc.numPages) renderPage(++currentPage); });

  // Tarih seçilmeden buton disabled kalır
  const dateInput = document.getElementById('pdfDate') as HTMLInputElement;
  const timeInput = document.getElementById('pdfTime') as HTMLSelectElement;
  const submitBtn = document.getElementById('pdfSubmitBtn') as HTMLButtonElement;
  const scheduleHint = document.getElementById('pdfScheduleHint') as HTMLParagraphElement;
  const meetingTypeInputs = [
    ...document.querySelectorAll<HTMLInputElement>('input[name="meetingType"]'),
  ];
  const SCHEDULE_RULES = {
    online: {
      allowedDays: [1, 2, 4, 5],
      timeSlots: [
        '10:00',
        '10:30',
        '11:00',
        '11:30',
        '12:00',
        '12:30',
        '13:00',
        '13:30',
        '14:00',
        '14:30',
        '15:00',
        '15:30',
        '16:00',
        '16:30',
      ],
      hint: 'Online gorusmeler Pazartesi, Sali, Persembe ve Cuma gunleri 10:00-16:30 arasinda her 30 dakikada bir planlanir.',
    },
    yuzyuze: {
      allowedDays: [3],
      timeSlots: [
        '09:00',
        '10:00',
        '11:00',
        '12:00',
        '13:00',
        '14:00',
        '15:00',
        '16:00',
        '17:00',
      ],
      hint: 'Yuz yuze gorusmeler yalnizca Carsamba gunleri 09:00-17:00 arasinda her saat basi planlanir.',
    },
  } as const;
  const today = new Date().toISOString().split('T')[0];

  const formatDateValue = (date: Date) => {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  };

  const getSelectedMeetingType = () =>
    meetingTypeInputs.find((input) => input.checked)?.value as keyof typeof SCHEDULE_RULES | undefined;

  const getNextAllowedDate = (meetingType: keyof typeof SCHEDULE_RULES) => {
    const candidate = new Date();
    candidate.setHours(0, 0, 0, 0);

    for (let offset = 0; offset < 21; offset += 1) {
      const next = new Date(candidate);
      next.setDate(candidate.getDate() + offset);
      if (SCHEDULE_RULES[meetingType].allowedDays.includes(next.getDay())) {
        return formatDateValue(next);
      }
    }

    return today;
  };

  const populateTimeSlots = (meetingType: keyof typeof SCHEDULE_RULES | undefined) => {
    timeInput.innerHTML = '';

    if (!meetingType || !dateInput.value) {
      timeInput.innerHTML = '<option value="">Once tarih secin</option>';
      timeInput.disabled = true;
      return;
    }

    timeInput.disabled = false;
    timeInput.innerHTML = '<option value="">Saat secin</option>';
    const now = new Date();
    const selectedDate = new Date(`${dateInput.value}T00:00:00`);
    const isToday = dateInput.value === formatDateValue(now);
    const availableSlots = SCHEDULE_RULES[meetingType].timeSlots.filter((slot) => {
      if (!isToday) return true;
      const [hours, minutes] = slot.split(':').map(Number);
      const slotDate = new Date(selectedDate);
      slotDate.setHours(hours, minutes, 0, 0);
      return slotDate.getTime() > now.getTime();
    });

    if (!availableSlots.length) {
      timeInput.innerHTML = '<option value="">Bu tarih icin uygun saat kalmadi</option>';
      timeInput.disabled = true;
      return;
    }

    availableSlots.forEach((slot) => {
      const option = document.createElement('option');
      option.value = slot;
      option.textContent = slot;
      timeInput.append(option);
    });
  };

  const validateSelectedDate = () => {
    const meetingType = getSelectedMeetingType();
    if (!meetingType || !dateInput.value) return;

    const selectedDate = new Date(`${dateInput.value}T00:00:00`);
    const isAllowed = SCHEDULE_RULES[meetingType].allowedDays.includes(selectedDate.getDay());

    if (!isAllowed) {
      dateInput.value = '';
      timeInput.value = '';
      timeInput.disabled = true;
      timeInput.innerHTML = '<option value="">Uygun tarih secin</option>';
      dateInput.setCustomValidity('Sectiginiz gorusme turu icin bu tarih uygun degil.');
      dateInput.reportValidity();
      return false;
    }

    dateInput.setCustomValidity('');
    return true;
  };

  const updateSubmitState = () => {
    submitBtn.disabled = !(getSelectedMeetingType() && dateInput.value && timeInput.value);
  };

  const applyMeetingType = () => {
    const meetingType = getSelectedMeetingType();

    dateInput.value = '';
    timeInput.value = '';

    if (!meetingType) {
      dateInput.disabled = true;
      timeInput.disabled = true;
      timeInput.innerHTML = '<option value="">Once tarih secin</option>';
      scheduleHint.textContent = 'Once gorusme turunu secin.';
      updateSubmitState();
      return;
    }

    dateInput.disabled = false;
    dateInput.min = getNextAllowedDate(meetingType);
    scheduleHint.textContent = SCHEDULE_RULES[meetingType].hint;
    timeInput.disabled = true;
    timeInput.innerHTML = '<option value="">Once tarih secin</option>';
    updateSubmitState();
  };

  meetingTypeInputs.forEach((input) => {
    input.addEventListener('change', applyMeetingType);
  });

  dateInput.min = today;
  dateInput.addEventListener('change', () => {
    const isValid = validateSelectedDate();
    populateTimeSlots(isValid ? getSelectedMeetingType() : undefined);
    updateSubmitState();
  });

  timeInput.addEventListener('change', updateSubmitState);
</script>

<style>
  .pdf-page {
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 5rem;
    background: var(--color-bg, #f8f5f1);
  }

  .pdf-back-wrap {
    max-width: 1200px;
    margin: 0 auto 2rem;
    padding: 0 2rem;
  }

  .pdf-back {
    font-size: 0.9rem;
    opacity: 0.55;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .pdf-back:hover { opacity: 1; }

  .pdf-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 3.5rem;
    align-items: start;
  }

  /* PDF Sol */
  #pdfCanvas {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.12);
    display: block;
  }

  .pdf-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .pdf-controls button {
    background: none;
    border: 1px solid currentColor;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    cursor: pointer;
    font-size: 1rem;
    opacity: 0.65;
    transition: opacity 0.2s;
  }

  .pdf-controls button:hover { opacity: 1; }
  .pdf-controls-bar {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: rgba(22, 19, 19, 0.88);
    color: #f8f5f1;
    border-radius: 999px;
    padding: 0.6rem 1.5rem;
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.2);
    z-index: 100;
  }

  .pdf-controls-bar button {
    background: none;
    border: none;
    color: inherit;
    font-size: 1.1rem;
    cursor: pointer;
    opacity: 0.75;
    transition: opacity 0.2s;
    padding: 0.2rem 0.4rem;
  }

  .pdf-controls-bar button:hover { opacity: 1; }
  .pdf-controls-bar button[disabled] { opacity: 0.2; cursor: default; }
  #pageInfo { font-size: 0.88rem; opacity: 0.7; min-width: 3.5rem; text-align: center; }

  /* Sağ Panel */
  .pdf-right {
    position: sticky;
    top: 7rem;
  }

  .pdf-cta-block {
    margin-bottom: 2rem;
  }

  .pdf-cta-block h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin: 0.5rem 0 0.75rem;
    line-height: 1.2;
  }

  .pdf-cta-desc {
    font-size: 0.95rem;
    opacity: 0.65;
    line-height: 1.7;
  }

  /* Form */
  .pdf-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: rgba(255,255,255,0.6);
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 16px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
  }

  .pdf-form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pdf-form-group label {
    font-size: 0.82rem;
    font-weight: 500;
    opacity: 0.65;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pdf-form-group input,
  .pdf-form-group select,
  .pdf-form-group textarea {
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.95rem;
    background: rgba(255,255,255,0.8);
    font-family: inherit;
    color: inherit;
    transition: border-color 0.2s;
    outline: none;
  }

  .pdf-form-group input:focus,
  .pdf-form-group select:focus,
  .pdf-form-group textarea:focus {
    border-color: rgba(0,0,0,0.35);
  }

  .pdf-form-group input:disabled,
  .pdf-form-group select:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    background: rgba(239,239,239,0.75);
  }

  .pdf-form-group textarea {
    min-height: 90px;
    resize: vertical;
  }

  .pdf-form-submit {
    margin-top: 0.25rem;
    padding: 0.85rem 1.5rem;
    background: #161313;
    color: #f8f5f1;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .pdf-form-submit:hover { opacity: 0.85; }
  .pdf-form-submit:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .pdf-type-group {
    display: flex;
    gap: 0.75rem;
  }

  .pdf-type-option {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    cursor: pointer;
    font-size: 0.95rem;
    padding: 0.55rem 1.1rem;
    border: 1px solid rgba(0,0,0,0.15);
    border-radius: 8px;
    background: rgba(255,255,255,0.8);
    transition: border-color 0.2s, background 0.2s;
    user-select: none;
  }
  .pdf-type-option input[type="radio"] { accent-color: #3b1f55; }
  .pdf-type-option:has(input:checked) {
    border-color: #3b1f55;
    background: rgba(59,31,85,0.06);
  }

  .pdf-helper {
    font-size: 0.78rem;
    line-height: 1.5;
    color: #6b5c51;
    opacity: 0.9;
  }

  /* Mobil */
  @media (max-width: 900px) {
    .pdf-layout {
      grid-template-columns: 1fr;
    }

    .pdf-right {
      position: static;
    }
  }
</style>
