---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { getSiteData } from '../lib/site-data';

const { siteConfig, servicesContent } = await getSiteData();
const images = servicesContent.marqueeImages as string[];
---

<BaseLayout
  title={`Galeri | ${siteConfig.brandName}`}
  description="Seminer, etkinlik ve çalışma görselleri."
>
  <Navbar />

  <main class="galeri-main">
    <section class="galeri-body">
      <p class="section-tag">Galeri</p>
      <h1 class="galeri-title">Çalışmalardan <em>kareler</em></h1>

      <div class="galeri-grid">
        {images.map((src: string) => (
          <div class="galeri-item">
            <img src={src} alt="Galeri görseli" loading="lazy" />
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .galeri-main {
    margin-top: 5rem;
  }

  @media (max-width: 768px) {
    .galeri-main {
      margin-top: 4rem;
    }
  }

  .galeri-body {
    max-width: min(1100px, 100%);
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .galeri-title {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--clr-deep);
    line-height: 1.15;
    margin: 0.75rem 0 2rem;
  }

  .galeri-title em {
    font-style: italic;
    color: var(--clr-terracotta);
  }

  .galeri-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .galeri-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.6rem;
    }
  }

  .galeri-item {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--clr-warm);
  }

  .galeri-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--ease-out);
  }

  .galeri-item:hover img {
    transform: scale(1.04);
  }
</style>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () =>
      nav.classList.toggle('scrolled', window.scrollY > 60), { passive: true }
    );
  }
</script>
